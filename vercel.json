{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "success.html",
          "privacy.html",
          "termini.html",
          "hero.png",
          "laila.png",
          "product-thumb.png",
          "prima.png",
          "prima-2.png",
          "prima-3.png",
          "prima-4.png",
          "dopo.png",
          "dopo-2.png",
          "dopo-3.png",
          "dopo-4.png"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
