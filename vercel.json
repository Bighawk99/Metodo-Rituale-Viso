{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "success.html",
          "privacy.html",
          "termini.html",
          "hero.png",
          "laila.png",
          "product-thumb.png",
          "prima.png",
          "prima-2.png",
          "prima-3.png",
          "prima-4.png",
          "dopo.png",
          "dopo-2.png",
          "dopo-3.png",
          "dopo-4.png",
          "guida.pdf",
          "admin.html",
          "hero.webp",
          "laila.webp",
          "product-thumb.webp",
          "prima.webp","prima-2.webp","prima-3.webp","prima-4.webp",
          "dopo.webp","dopo-2.webp","dopo-3.webp","dopo-4.webp"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "server.js" }
  ]
}
